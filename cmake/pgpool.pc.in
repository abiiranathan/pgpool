prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${exec_prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: pgpool
Description: PostgreSQL connection pool library
Version: @PROJECT_VERSION@
Requires: libpq
Libs: -L${libdir} -lpgpool
Cflags: -I${includedir}/pgpool
